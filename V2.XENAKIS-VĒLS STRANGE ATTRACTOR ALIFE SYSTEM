import numpy as np
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation

# =========================================================
# XENAKIS‑VĒLS STRANGE‑ATTRACTOR ARTIFICIAL LIFE SYSTEM
# =========================================================

# ---------- organism dynamics ----------
def step(x, y, z, p):
    a, b, c, d, e = p

    x_new = np.sin(a * y) + e * np.cos(b * x)
    y_new = np.sin(b * z) + e * np.cos(c * y)
    z_new = np.sin(c * x) - np.cos(d * z)

    return x_new, y_new, z_new


# ---------- genome mutation ----------
def mutate(genome):
    g = genome.copy()

    # continuous drift
    g += np.random.normal(0, 0.004, 5)

    # rare structural mutation (speciation)
    if np.random.rand() < 0.02:
        g += np.random.normal(0, 0.08, 5)

    return g


# ---------- fitness function ----------
def fitness(traj):
    traj = np.array(traj)

    stability = 1 / (1 + np.std(traj))
    spread = np.mean(np.linalg.norm(traj - np.mean(traj, axis=0), axis=1))

    return 0.7 * stability + 0.3 * (spread / (1 + spread))


# ---------- initial organism ----------
def spawn():
    return {
        "state": np.random.uniform(-1, 1, 3),
        "genome": np.array([1.4, -1.6, 1.0, -0.7, 0.5]),
        "species": np.random.randint(0, 10)
    }


# ---------- simulation step ----------
def simulate(pop, steps=250, max_pop=40):
    new_pop = []
    frame = []

    for org in pop:
        x, y, z = org["state"]
        g = org["genome"]

        traj = []
        p = g.copy()

        for _ in range(steps):
            x, y, z = step(x, y, z, p)

            # internal adaptive drift
            p += 0.002 * np.array([
                np.sin(z),
                np.cos(x),
                np.sin(y),
                np.cos(z),
                np.sin(x + y)
            ])

            traj.append((x, y, z))

        fit = fitness(traj)

        if fit > 0.25:
            frame.append((np.array(traj), org["species"]))

            # reproduction proportional to fitness
            offspring = int(1 + fit * 3)

            for _ in range(offspring):
                new_pop.append({
                    "state": np.array([x, y, z]) + np.random.normal(0, 0.05, 3),
                    "genome": mutate(g),
                    "species": org["species"]
                })

    # ecological pressure
    if len(new_pop) > max_pop:
        new_pop = list(np.random.choice(new_pop, max_pop, replace=False))

    return new_pop, frame


# ---------- visualization ----------
colors = plt.cm.hsv(np.linspace(0, 1, 10))

fig = plt.figure(figsize=(8, 8))
ax = fig.add_subplot(111, projection='3d')
ax.set_axis_off()

population = [spawn() for _ in range(35)]
angle = 0

def update(frame_id):
    global population, angle

    ax.clear()
    ax.set_axis_off()
    ax.view_init(elev=30, azim=angle)

    population, frame = simulate(population)

    for traj, species in frame:
        color = colors[species % len(colors)]
        ax.plot(traj[:, 0], traj[:, 1], traj[:, 2],
                linewidth=0.5,
                color=color,
                alpha=0.7)

    ax.set_title(f"Xenakis‑Vēls ALife — t={frame_id}", fontsize=10)
    angle += 2


ani = FuncAnimation(fig, update, interval=120)
plt.show()
